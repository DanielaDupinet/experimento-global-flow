{
  "name": "nuds-library",
  "private": true,
  "version": "0.5.3",
  "description": "Project-ignition (nuds-library) monorepo (React Native + web-ready)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prestorybook": "echo \"Storybook local mode uses workspace source\"",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local expo start --clear",
    "storybook:local": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local expo start --clear",
    "prestorybook:ios": "echo \"Storybook local iOS mode uses workspace source\"",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local expo run:ios",
    "storybook:local:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local expo run:ios",
    "storybook:live": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local CI= expo start --clear",
    "storybook:ios:live": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=local CI= expo run:ios",
    "ios:pod-install": "pod install --project-directory=ios --repo-update",
    "storybook:ios:sync": "npm install && npm run ios:pod-install && npm run storybook:ios:live",
    "prestorybook:package": "npm run build",
    "storybook:package": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=package expo start --clear",
    "prestorybook:package:ios": "npm run build",
    "storybook:package:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true EXPO_PUBLIC_NUDS_SOURCE_MODE=package expo run:ios",
    "web": "expo start --web",
    "release": "node ./scripts/release.mjs",
    "release:patch": "node ./scripts/release.mjs patch",
    "release:minor": "node ./scripts/release.mjs minor",
    "release:major": "node ./scripts/release.mjs major",
    "lint:colors": "node ./scripts/check-no-raw-colors.mjs",
    "figma:scan": "node ./scripts/scan-figma-library.mjs",
    "figma:validate": "node ./scripts/validate-figma-mapping.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run -ws typecheck",
    "build": "npm run -w @nu-design-org/nuds-vibecode-tokens build && npm run -w @nu-design-org/nuds-vibecode-theme build && npm run -w @nu-design-org/nuds-vibecode-react-native build && npm run -w @nu-design-org/nuds-vibecode-react-web build",
    "clean": "npm run -ws clean",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "expo": "^54.0.33",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "^3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-is-edge-to-edge": "^1.2.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@storybook/addon-ondevice-actions": "^10.2.1",
    "@storybook/addon-ondevice-controls": "^10.2.1",
    "@storybook/react-native": "^10.2.1",
    "vitest": "^4.0.18"
  }
}
